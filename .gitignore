# Generated by `make` (go run ./gen): the unscrambled MP3404 ROM, the
# title sprite bitmaps, the SID frequency table, the transcribed sound
# table, and the linked PRG. The mask-ROM bytes are never committed.
rom.bin
sprites.bin
sidfreq.bin
songs.bin
merlin.prg

